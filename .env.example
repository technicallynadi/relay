# --- Models ---
# Recommended: OpenRouter. One key gives the judge panel a genuine cross-family roster
# (e.g. anthropic/claude-*, openai/gpt-*, meta-llama/*) — the evidence-backed diversity.
# Used for the four agents + the committee judges at runtime.
OPENROUTER_API_KEY=

# Embeddings are precomputed ONCE at seed time, so there are zero embedding calls during
# the live demo. Default uses OpenAI text-embedding-3-small.
OPENAI_API_KEY=

# Optional: route the agents through Anthropic directly instead of OpenRouter.
ANTHROPIC_API_KEY=

# Optional overrides (sensible defaults applied if unset)
# Judge models default in data/judges.ts and are overridable per-judge in relay.config.yaml
# (judges: { matchmaker: openai/gpt-4o-mini, ... }). Check them: bun run scripts/check-models.ts
# MIN_AGREEMENT=0.6            # required jury agreement (Kendall's W) to auto-route; the UI dial overrides this live
# WORKER_CRON=*/6 * * * * *    # ingestion-worker schedule for the live feed (./run.sh worker)
# LLM_FALLBACK_MODELS=openai/gpt-4o-mini,google/gemini-2.5-flash  # when a model can't be afforded, retry down this chain (then deterministic)

# --- Send delivery (optional) ---
# The human gate's "Send" simulates by default. Add a provider to deliver the handoff for real:
# TWILIO_ACCOUNT_SID=          # SMS via Twilio
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+15551234567
# RESEND_API_KEY=              # or email via Resend
# RESEND_FROM=Relay <onboarding@resend.dev>
# DEMO_RECIPIENT=              # phone (SMS) or email the demo handoff goes to

# --- Partner sourcing (optional) ---
# Local partners are seeded behind a Google-Places-shaped adapter. Add a Places key to
# pull live local businesses for each opportunity's target trade instead of the seed.
# GOOGLE_PLACES_API_KEY=        # Google Places API (New) — Text Search
